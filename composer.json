{
    "name": "hexawebsystems/laravel-hexa-package-wordpress",
    "description": "WordPress - REST API connector for post management, site configuration, and remote content publishing.",
    "type": "library",
    "version": "2.0.45",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "hexawebsystems/laravel-hexa-package-media": "*",
        "hexawebsystems/laravel-hexa-package-notion": "*",
        "hexawebsystems/laravel-hexa-package-user-roles": "*",
        "hexawebsystems/laravel-hexa-package-whm": "*",
        "hexawebsystems/laravel-hexa-package-wptoolkit": "*"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_wordpress\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_wordpress\\Providers\\WordPressServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
