{
    "name": "hexawebsystems/laravel-hexa-package-wordpress",
    "description": "WordPress \u2014 REST API connector for post management, site configuration, and remote content publishing.",
    "type": "library",
    "version": "0.1.12",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_wordpress\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_wordpress\\Providers\\WordPressServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
